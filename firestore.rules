rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Keep this list in sync with VITE_SUPERADMIN_EMAILS — this is the real
    // enforcement point, the env var is UI-only.
    function isSuperAdminEmail() {
      return request.auth != null &&
        request.auth.token.email in [
          'vaibhavvakil1234@gmail.com'
          // add more superadmin emails here, one per line
        ];
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Defense in depth: also honor a Firestore-recorded SUPERADMIN role, so
    // a superadmin added after go-live doesn't require a rules redeploy.
    function isSuperAdminDoc() {
      return hasUserDoc() && currentUserDoc().role == 'SUPERADMIN';
    }

    function isSuperAdmin() {
      return isSuperAdminEmail() || isSuperAdminDoc();
    }

    // A hospital admin managing their own hospital's doctors, receptionists,
    // patients and appointments — never someone else's hospital.
    function isHospitalAdminOf(hospitalId) {
      return hasUserDoc() &&
        currentUserDoc().role == 'HOSPITAL_ADMIN' &&
        currentUserDoc().hospitalId == hospitalId &&
        currentUserDoc().status == 'active';
    }

    // Any active staff member (of any role) of the given hospital — used
    // for patient/appointment access, and for cross-role visibility (e.g.
    // a receptionist listing doctors, a doctor's own dashboard).
    function isHospitalStaffOf(hospitalId) {
      return hasUserDoc() &&
        currentUserDoc().hospitalId == hospitalId &&
        currentUserDoc().status == 'active';
    }

    // Reusable guard for any collection that belongs to an optional module
    // (e.g. a future chatbotThreads/{id} doc). Only meant for non-core
    // features — core modules (patients, appointments, ...) are always on
    // and don't need this. See NEW_MODULE_DEVELOPMENT_GUIDE.md.
    function hospitalHasFeature(hospitalId, featureKey) {
      return exists(/databases/$(database)/documents/hospitalFeatures/$(hospitalId)) &&
        get(/databases/$(database)/documents/hospitalFeatures/$(hospitalId)).data.features[featureKey] == true;
    }

    // Whether this staff member may operate Billing for their own hospital.
    // Hospital Admin always can; a Receptionist can unless access has been
    // turned off for them via EITHER of two fields on their own user doc —
    // the original per-hospital-admin `billingAccess` boolean toggle (see
    // setUserBillingAccess in firebase/users.js), or the newer, more
    // general Super-Admin-assigned `permissions.billing` level (see
    // setUserModulePermission and src/utils/permissions.js). Both default
    // to "allowed" when missing (get(field, true) / != 'none'), so every
    // receptionist that existed before either field was added keeps working
    // exactly as before; either field explicitly denying access takes it
    // away. setUserBillingAccess/setUserModulePermission always write both
    // fields together going forward, so they can only disagree on a
    // receptionist whose `billingAccess` was set to false before the
    // `permissions` map existed and hasn't been touched since — in that one
    // historical case, access stays denied until either field is touched
    // again.
    function isBillingStaffOf(hospitalId) {
      return hasUserDoc() &&
        currentUserDoc().status == 'active' &&
        currentUserDoc().hospitalId == hospitalId &&
        (currentUserDoc().role == 'HOSPITAL_ADMIN' ||
         (currentUserDoc().role == 'RECEPTIONIST' &&
          currentUserDoc().get('billingAccess', true) == true &&
          currentUserDoc().get('permissions', {}).get('billing', 'edit') != 'none')) &&
        hospitalHasFeature(hospitalId, 'billing');
    }

    // A doctor may update their own record (schedule, specialization,
    // display name) but never their role, hospital, status or email —
    // those stay hospital-admin/superadmin-only.
    function isSelfDoctorScheduleUpdate(uid) {
      return request.auth != null && request.auth.uid == uid &&
        resource.data.role == 'DOCTOR' &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.hospitalId == resource.data.hospitalId &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.email == resource.data.email;
    }

    // Doctor directory entries (name, specialization, schedule) are
    // intentionally public — patients need them to pick a doctor when
    // booking, without any login.
    function isActiveDoctorDoc() {
      return resource.data.role == 'DOCTOR' && resource.data.status == 'active';
    }

    match /hospitals/{slug} {
      allow read: if true; // public tenant landing pages read without auth
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{uid} {
      allow get: if isActiveDoctorDoc() ||
        (request.auth != null &&
          (request.auth.uid == uid || isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId)));
      allow list: if isActiveDoctorDoc() || isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);

      allow create: if isSuperAdmin() ||
        (isHospitalAdminOf(request.resource.data.hospitalId) &&
         request.resource.data.role in ['DOCTOR', 'RECEPTIONIST']);

      // A hospital admin may update their own doctors'/receptionists'
      // status and schedule, but never change their role or move them to
      // a different hospital (that would be a privilege-escalation path).
      // A doctor may separately update only their own record's schedule.
      allow update: if isSuperAdmin() ||
        (isHospitalAdminOf(resource.data.hospitalId) &&
         resource.data.role in ['DOCTOR', 'RECEPTIONIST'] &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.hospitalId == resource.data.hospitalId) ||
        isSelfDoctorScheduleUpdate(uid);

      allow delete: if isSuperAdmin();
    }

    match /patients/{patientId} {
      allow read: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      // Public self-service booking creates its own patient record — no
      // login, so this can only be shape-checked, not identity-checked.
      allow create: if isHospitalStaffOf(request.resource.data.hospitalId) ||
        (request.resource.data.hospitalId is string &&
         request.resource.data.name is string &&
         request.resource.data.phone is string);
      allow update: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow delete: if isSuperAdmin();
    }

    match /appointments/{appointmentId} {
      // The doc ID doubles as an unguessable public lookup token (see
      // getAppointmentByToken) — anyone who has it can fetch that one
      // appointment, but never enumerate the collection (allow list stays
      // staff-only below).
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      // Staff book already-confirmed appointments; the public booking page
      // may only create ones that start 'pending' front-desk confirmation.
      allow create: if isHospitalStaffOf(request.resource.data.hospitalId) ||
        (request.resource.data.status == 'pending' && request.resource.data.bookedBy == 'patient');
      allow update: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow delete: if isSuperAdmin();
    }

    // Doc ID is `{hospitalId}::{digitsOnlyPhone}` — lets the public status
    // page resolve "my appointments" from a phone number alone via a
    // direct get-by-ID, the same unguessable-ID pattern as appointment
    // tokens, without ever exposing an open query across all patients.
    match /phoneLookup/{lookupId} {
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow create, update: if request.resource.data.hospitalId is string && request.resource.data.tokens is list;
      allow delete: if isSuperAdmin();
    }

    // Doc ID is `{hospitalId}::{doctorId}::{date}` — which times are
    // already claimed (pending-with-a-time or confirmed) for that doctor on
    // that date. Deliberately holds no patient info, so it's safe to expose
    // publicly: this is what lets the unauthenticated booking form grey out
    // taken slots, and what createAppointment/confirmAppointment/
    // rescheduleAppointment check+update atomically to prevent double-
    // booking. Staff (creating/confirming/rescheduling appointments
    // directly) need to write it too, not just the public flow.
    match /doctorSlots/{slotId} {
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow create, update: if (request.resource.data.hospitalId is string &&
                                 request.resource.data.doctorId is string &&
                                 request.resource.data.date is string &&
                                 request.resource.data.times is list) ||
                                isHospitalStaffOf(request.resource.data.hospitalId);
      allow delete: if isSuperAdmin();
    }

    // Doc ID is `{hospitalId}::{digitsOnlyPhone}::{date}` — counts a phone
    // number's public self-service bookings for one calendar date, capped
    // client-side at 2 (see MAX_PUBLIC_BOOKINGS_PER_PHONE_PER_DAY) and
    // re-enforced here so it can't be bypassed by calling the SDK directly:
    // a create must start at count 1, and each update must increment by
    // exactly 1 and never exceed 2. Only the public booking flow touches
    // this — staff booking on a patient's behalf isn't capped.
    match /phoneDailyCounts/{countId} {
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow create: if request.resource.data.hospitalId is string &&
                       request.resource.data.phone is string &&
                       request.resource.data.date is string &&
                       request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1 &&
                       request.resource.data.count <= 2;
      allow delete: if isSuperAdmin();
    }

    // Per-hospital module toggles (see src/config/featureRegistry.js and
    // src/firebase/hospitalFeatures.js). Doc ID == hospitalId. Staff of the
    // hospital may read their own flags (the client feature-gate depends on
    // it); only the Super Admin may ever write them — this is the real,
    // server-side enforced version of "Super Admin decides which hospitals
    // can use it," independent of anything the client sends.
    match /hospitalFeatures/{hospitalId} {
      allow get: if isSuperAdmin() || isHospitalStaffOf(hospitalId);
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Billing module (src/config/featureRegistry.js key 'billing'). One
    // invoice per appointment — doc id == appointmentId (see createInvoice
    // in src/firebase/billing.js). Feature-gated because, unlike
    // appointments/patients, this collection has no reason to exist for a
    // hospital that hasn't turned Billing on.
    match /invoices/{invoiceId} {
      // Split from `list` deliberately: a `get` can target an id that
      // doesn't exist yet (resource is then null), so resource.data must be
      // guarded by exists() first — referencing it unconditionally errors
      // out as permission-denied even for a legitimately-authorized caller,
      // which is exactly what broke createInvoice() before it stopped
      // doing its own pre-check (see the comment there). `list` never has
      // this problem: a query only ever evaluates rules against documents
      // that do exist.
      allow get: if isSuperAdmin() ||
        (exists(/databases/$(database)/documents/invoices/$(invoiceId)) &&
         isHospitalStaffOf(resource.data.hospitalId) &&
         hospitalHasFeature(resource.data.hospitalId, 'billing'));
      allow list: if isSuperAdmin() ||
        (isHospitalStaffOf(resource.data.hospitalId) && hospitalHasFeature(resource.data.hospitalId, 'billing'));

      // The doc id must equal its own appointmentId (one invoice per visit,
      // enforced here too, not just by the client — see createInvoice's
      // comment) and the money fields must be internally consistent, so a
      // client can't call the SDK directly to forge a total that doesn't
      // match its own line items.
      allow create: if isBillingStaffOf(request.resource.data.hospitalId) &&
        request.resource.data.status == 'due' &&
        request.resource.data.appointmentId == invoiceId &&
        request.resource.data.lineItems is list && request.resource.data.lineItems.size() > 0 &&
        request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 &&
        request.resource.data.discount is number && request.resource.data.discount >= 0 &&
        request.resource.data.total is number && request.resource.data.total >= 0 &&
        request.resource.data.total == request.resource.data.subtotal - request.resource.data.discount;

      // Three, and only three, ways an invoice may change after creation —
      // nothing else is ever allowed, so a client can't smuggle an amount
      // edit in alongside a status change:
      //   1) add a charge (room, dressing, tests, ...) — only while still
      //      'due', lineItems/subtotal only ever grow, identity fixed;
      //   2) record a payment, full or partial — `amountPaid` may only
      //      increase (never past `total`), status flips to 'paid' only
      //      once it reaches `total` and otherwise must stay 'due'; every
      //      other money/identity field frozen exactly as it was. The
      //      per-payment history (who paid what, when) lives in the
      //      separate /invoicePayments collection below, not as an array
      //      on this doc — Firestore doesn't support serverTimestamp()
      //      inside array elements, and keeping `amountPaid` flat here
      //      (rather than derived from summing that collection) means every
      //      page that already reads invoices for stats/lists still needs
      //      zero extra queries to know what's outstanding.
      //   3) void — Hospital Admin only, from any non-void status, every
      //      money/identity field frozen exactly as it was.
      allow update: if
        (
          isBillingStaffOf(resource.data.hospitalId) &&
          resource.data.status == 'due' &&
          request.resource.data.status == 'due' &&
          request.resource.data.hospitalId == resource.data.hospitalId &&
          request.resource.data.appointmentId == resource.data.appointmentId &&
          request.resource.data.lineItems is list &&
          request.resource.data.lineItems.size() >= resource.data.lineItems.size() &&
          request.resource.data.subtotal is number && request.resource.data.subtotal >= resource.data.subtotal &&
          request.resource.data.discount is number && request.resource.data.discount >= 0 &&
          request.resource.data.total is number && request.resource.data.total >= 0 &&
          request.resource.data.total == request.resource.data.subtotal - request.resource.data.discount
        ) ||
        (
          isBillingStaffOf(resource.data.hospitalId) &&
          resource.data.status == 'due' &&
          request.resource.data.hospitalId == resource.data.hospitalId &&
          request.resource.data.appointmentId == resource.data.appointmentId &&
          request.resource.data.lineItems == resource.data.lineItems &&
          request.resource.data.subtotal == resource.data.subtotal &&
          request.resource.data.discount == resource.data.discount &&
          request.resource.data.total == resource.data.total &&
          request.resource.data.amountPaid is number &&
          request.resource.data.amountPaid > resource.data.get('amountPaid', 0) &&
          request.resource.data.amountPaid <= resource.data.total &&
          request.resource.data.status ==
            (request.resource.data.amountPaid >= resource.data.total ? 'paid' : 'due')
        ) ||
        (
          isHospitalAdminOf(resource.data.hospitalId) &&
          hospitalHasFeature(resource.data.hospitalId, 'billing') &&
          resource.data.status != 'void' &&
          request.resource.data.status == 'void' &&
          request.resource.data.hospitalId == resource.data.hospitalId &&
          request.resource.data.appointmentId == resource.data.appointmentId &&
          request.resource.data.lineItems == resource.data.lineItems &&
          request.resource.data.subtotal == resource.data.subtotal &&
          request.resource.data.discount == resource.data.discount &&
          request.resource.data.total == resource.data.total
        ) ||
        isSuperAdmin();

      allow delete: if isSuperAdmin();
    }

    // Sequential, human-readable invoice numbers (see createInvoice in
    // src/firebase/billing.js) — doc id == hospitalId, same atomic-counter
    // pattern as phoneDailyCounts above: a create must start at count 1, and
    // each update must increment by exactly 1, so two concurrent invoice
    // creations for the same hospital can never collide on the same number.
    match /invoiceCounters/{hospitalId} {
      allow get: if isSuperAdmin() || isHospitalStaffOf(hospitalId);
      allow create: if isBillingStaffOf(hospitalId) && request.resource.data.count == 1;
      allow update: if isBillingStaffOf(hospitalId) &&
        request.resource.data.count == resource.data.count + 1;
      allow delete: if isSuperAdmin();
    }

    // Payment history for invoices — one doc per (possibly partial) payment.
    // Kept as its own collection instead of an array field on the invoice
    // itself because Firestore doesn't support serverTimestamp() inside
    // array elements; see the comment on the /invoices update rule above for
    // why `amountPaid` (the number every stats/list view actually needs)
    // still lives flat on the invoice doc rather than being derived by
    // summing these. This collection is purely for the "payment history"
    // list in InvoiceDetailModal — nothing else reads it.
    match /invoicePayments/{paymentId} {
      allow get: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow create: if isBillingStaffOf(request.resource.data.hospitalId) &&
        request.resource.data.invoiceId is string &&
        request.resource.data.amount is number && request.resource.data.amount > 0;
      allow update, delete: if isSuperAdmin();
    }

    // Bed & Ward Management module — bedConfig stores the floor/ward/room/bed
    // hierarchy for each hospital (one doc per hospital, id == hospitalId),
    // admissions stores individual admission records. Both are feature-gated
    // on the 'bedManagement' key.
    match /bedConfig/{hospitalId} {
      allow get: if isHospitalStaffOf(hospitalId) &&
        hospitalHasFeature(hospitalId, 'bedManagement');
      allow list: if false;
      allow create, update: if isHospitalAdminOf(hospitalId) &&
        hospitalHasFeature(hospitalId, 'bedManagement');
      allow delete: if false;
    }

    match /admissions/{admissionId} {
      allow read: if isHospitalStaffOf(resource.data.hospitalId) &&
        hospitalHasFeature(resource.data.hospitalId, 'bedManagement');
      allow list: if isHospitalStaffOf(resource.data.hospitalId) &&
        hospitalHasFeature(resource.data.hospitalId, 'bedManagement');
      allow create: if isHospitalStaffOf(request.resource.data.hospitalId) &&
        hospitalHasFeature(request.resource.data.hospitalId, 'bedManagement');
      allow update: if isHospitalStaffOf(resource.data.hospitalId) &&
        hospitalHasFeature(resource.data.hospitalId, 'bedManagement');
      allow delete: if false;
    }

    // Prescriptions module (src/config/featureRegistry.js key
    // 'prescriptions') deliberately has NO collection/rule of its own — it
    // only presents data that already lives on `appointments` (the
    // `prescription`/`tests`/`concerns` fields written by
    // completeAppointmentWithNotes), which core Appointments access already
    // covers for every role that needs it. Per NEW_MODULE_DEVELOPMENT_GUIDE
    // §8: a feature flag only needs its own rule when it's the thing
    // protecting data nothing else already protects — here there's nothing
    // new to protect, so `hospitalHasFeature(..., 'prescriptions')` is
    // enforced client-side only (RequireFeature + the registry-driven nav),
    // same as it would be for any other read-only view over core data.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
